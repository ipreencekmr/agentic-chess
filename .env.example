OPENAI_API_KEY=your_openai_api_key_here
STOCKFISH_PATH=path_to_stockfish_binary_here
CHESS_ENGINE_MOVE_TIME=time_in_milliseconds_for_stockfish_moves_here

# Set to "true" to disable AI Agent difficulty mode (even if OpenAI API key is set)
DISABLE_AI_MODE=false

LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=your_langchain_project_name_here

CLEANUP_MODEL=gpt-4.1

OTEL_ENABLED: true_or_false_value_here
OTEL_SERVICE_NAME: agentic-chess
OTEL_EXPORTER_OTLP_ENDPOINT: http://jaeger:4317